      "settings": {
        "custom_liquid": "<style>\n  .kimlit-benefits {\n    max-width: 850px;\n    margin: 30px auto;\n    font-family: Arial, sans-serif;\n  }\n\n  .kimlit-benefits h2 {\n    text-align: center;\n    color: #0359ca;\n    font-size: 28px;\n    margin-bottom: 20px;\n  }\n\n  .kimlit-table {\n    width: 100%;\n    border-collapse: collapse;\n    overflow: hidden;\n    border-radius: 14px;\n    box-shadow: 0 4px 14px rgba(0,0,0,0.08);\n  }\n\n  .kimlit-table th {\n    background-color: #0359ca;\n    color: white;\n    padding: 14px;\n    font-size: 16px;\n    text-align: center;\n  }\n\n  .kimlit-table td {\n    padding: 14px;\n    text-align: center;\n    font-size: 15px;\n    border-bottom: 1px solid #eeeeee;\n  }\n\n  .kimlit-table td:first-child {\n    text-align: left;\n    font-weight: 600;\n    color: #222;\n  }\n\n  .yes {\n    color: #0359ca;\n    font-weight: 700;\n  }\n\n  .no {\n    color: #999;\n    font-weight: 700;\n  }\n\n  @media (max-width: 600px) {\n    .kimlit-benefits h2 {\n      font-size: 24px;\n    }\n\n    .kimlit-table th,\n    .kimlit-table td {\n      padding: 11px;\n      font-size: 13px;\n    }\n  }\n</style>\n\n<div class=\"kimlit-benefits\">\n  <h2>Why Choose Kimlit?</h2>\n\n  <table class=\"kimlit-table\">\n    <thead>\n      <tr>\n        <th>Benefits</th>\n        <th>Kimlit</th>\n        <th>Others</th>\n      </tr>\n    </thead>\n\n    <tbody>\n      <tr>\n        <td>Foldable & Portable Design</td>\n        <td class=\"yes\">Yes</td>\n        <td class=\"no\">No</td>\n      </tr>\n\n      <tr>\n        <td>Built-In Touchpad</td>\n        <td class=\"yes\">Yes</td>\n        <td class=\"no\">No</td>\n      </tr>\n\n      <tr>\n        <td>Wireless Connection</td>\n        <td class=\"yes\">Yes</td>\n        <td class=\"no\">No</td>\n      </tr>\n\n      <tr>\n        <td>Rechargeable Battery</td>\n        <td class=\"yes\">Yes</td>\n        <td class=\"no\">No</td>\n      </tr>\n\n      <tr>\n        <td>Perfect for Travel, Work & Study</td>\n        <td class=\"yes\">Yes</td>\n        <td class=\"no\">No</td>\n      </tr>\n    </tbody>\n  </table>\n</div>",
